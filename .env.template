# ═══════════════════════════════════════════════
# SpineDoc 环境配置
# ═══════════════════════════════════════════════
# 复制为 .env，替换 <YOUR_xxx> 为实际值

# ─── LLM（必填） ───
LLM_API_KEY=<YOUR_API_KEY>
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_ENDPOINT=<YOUR_ENDPOINT_ID>

# ─── Embedding（必填，硅基流动） ───
EMBEDDING_API_KEY=<YOUR_SILICONFLOW_KEY>

# ─── 联网搜索（必填，智谱） ───
ZHIPU_API_KEY=<YOUR_ZHIPU_KEY>

# ─── 飞书集成（必填） ───
FEISHU_APP_ID=<YOUR_APP_ID>
FEISHU_APP_SECRET=<YOUR_APP_SECRET>
FEISHU_BITABLE_TOKEN=<YOUR_BITABLE_TOKEN>              # 父表 token
FEISHU_BITABLE_TABLE_ID=<DOC_TABLE_ID>                # 文档表
FEISHU_BITABLE_CHUNK_TABLE_ID=<CHUNK_TABLE_ID>        # 分片表
FEISHU_BITABLE_TOC_TABLE_ID=<TOC_TABLE_ID>            # 目录表
FEISHU_BITABLE_MEMORY_TABLE_ID=<MEMORY_TABLE_ID>      # 记忆表
FEISHU_BITABLE_GALAXY_TABLE_ID=<GALAXY_TABLE_ID>      # 星系表
FEISHU_DEFAULT_CHAT_ID=oc_<YOUR_CHAT_ID>

# ─── OCR 熔炼（选填，处理 PDF 需要） ───
ARK_API_KEY=<YOUR_ARK_KEY>
ARK_ENDPOINT=<YOUR_ARK_ENDPOINT>

# ─── Aily（选填，AI 助手需要） ───
FEISHU_AILY_TOKEN=<YOUR_AILY_TOKEN>
