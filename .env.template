# ═══════════════════════════════════════════════════════════
# SpineDoc (阅脊) 配置文件模板
# ═══════════════════════════════════════════════════════════
# 使用说明:
# 1. 复制此文件为 .env
# 2. 替换所有 <YOUR_xxx> 为你的实际配置
# 3. 运行 spine setup 进行交互式配置（推荐）
# ═══════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════
# 🐳 第一步：安装 PostgreSQL 数据库
# ═══════════════════════════════════════════════════════════
# 使用 Docker 一键安装（推荐）:
#
# Windows / macOS / Linux:
#   docker run -d --name spinedoc-postgres ^
#     -e POSTGRES_PASSWORD=spinedoc123 ^
#     -p 5432:5432 postgres:15
#
# 或者使用 Docker Compose:
#   docker-compose up -d postgres
#
# 验证安装:
#   docker ps | findstr postgres
# ═══════════════════════════════════════════════════════════

# ========== 🗄️ 数据库配置（必需） ==========
# PostgreSQL 连接字符串
# 默认值适用于本地 Docker 安装
DATABASE_URL=postgresql+asyncpg://spinedoc:spinedoc123@localhost:5432/spinedoc


# ========== 🤖 LLM 配置（必需） ==========
# 推荐服务：DeepSeek (性价比高)
# 注册地址：https://platform.deepseek.com/
#
# 备选服务:
#   - OpenAI: https://api.openai.com/v1 (gpt-4o)
#   - Anthropic: https://api.anthropic.com/v1 (claude-sonnet-4-6-20251101)
#   - Moonshot: https://api.moonshot.cn/v1 (moonshot-v1-128k)
#   - 硅基流动：https://api.siliconflow.cn/v1 (deepseek-ai/DeepSeek-V3)
LLM_API_KEY=<YOUR_DEEPSEEK_API_KEY>
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL_NAME=deepseek-chat


# ========== 📐 向量模型配置（必需） ==========
# 推荐服务：SiliconFlow (BAAI/bge-m3)
# 注册地址：https://cloud.siliconflow.cn/
# 免费额度：每月 100 万 tokens
EMBEDDING_API_KEY=<YOUR_SILICONFLOW_API_KEY>
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DIMENSION=1024


# ========== 👁️ VLM 配置（必需，用于 OCR 和目录识别） ==========
# 推荐服务：SiliconFlow (Qwen2.5-VL-72B-Instruct)
# 可与向量模型共用同一个 API Key
VLM_API_KEY=<YOUR_SILICONFLOW_API_KEY>
VLM_BASE_URL=https://api.siliconflow.cn/v1
VLM_MODEL_NAME=Qwen/Qwen2.5-VL-72B-Instruct


# OCR 并发控制
OCR_MAX_CONCURRENT_REQUESTS=10
OCR_MAX_CONCURRENCY=1


# ========== 🌐 联网搜索配置（可选） ==========
# Tavily API 用于联网检索外部证据
# 注册地址：https://tavily.com/
# 免费额度：每月 1000 次搜索
# 留空则禁用联网功能
TAVILY_API_KEY=<YOUR_TAVILY_API_KEY>
TAVILY_MAX_RESULTS=3
TAVILY_SEARCH_DEPTH=advanced
TAVILY_CONCURRENT_LIMIT=5


# ========== 💾 缓存配置（可选） ==========
# 模型缓存目录
# Windows 示例：CACHE_DIR=E:/ai_models
# macOS/Linux 示例：CACHE_DIR=~/.cache/spinedoc
CACHE_DIR=./ai_models


# ========== ⚖️ 联邦法庭配置（可选，默认值即可） ==========
# Scout 查询数量限制
COURT_SCOUT_QUERY_LIMIT=5

# 上下文 TOC 显示上限
COURT_CONTEXT_TOC_LIMIT=30

# 权威分加成/惩罚系数
COURT_AUTHORITY_PEER_REVIEW_BONUS=1.15
COURT_AUTHORITY_USER_GENERATED_PENALTY=0.85
COURT_AUTHORITY_CROSS_SOURCE_BONUS=1.20


# ========== 📑 TOC 验证约束（可选，默认值即可） ==========
# 最大页数限制
TOC_MAX_PAGES_LIMIT=5000

# 最大深度限制
TOC_MAX_DEPTH_LIMIT=8

# 最大条目限制
TOC_MAX_ITEMS_LIMIT=1000


# ========== 📎 上下文截断配置（可选，默认值即可） ==========
# 逻辑标签数量限制
CONTEXT_LOGIC_TAGS_LIMIT=10

# 选择的证据 ID 数量限制
CONTEXT_SELECTED_IDS_LIMIT=5

# 默认回退 Chunk 数量
CONTEXT_FALLBACK_CHUNKS=3

# Git 提交前缀长度
CONTEXT_COMMIT_QUERY_PREFIX=30
CONTEXT_COMMIT_DOC_ID_PREFIX=8

# 证据内容预览长度
CONTEXT_EVIDENCE_CONTENT_PREFIX=150
CONTEXT_EVIDENCE_REASON_PREFIX=50

# Chunk 预览配置
CONTEXT_CHUNK_PREVIEW_KEYWORDS=5
CONTEXT_CHUNK_PREVIEW_CONTENT=200

# 向量批次处理文本长度
CONTEXT_VECTOR_BATCH_TEXT_PREFIX=1500


# ═══════════════════════════════════════════════════════════
# 配置完成后的验证
# ═══════════════════════════════════════════════════════════
# 1. 运行以下命令检查配置状态:
#    python spine_setup.py --check
#
# 2. 启动 SpineDoc:
#    python spine_setup.py --launch
#
# 3. 测试功能:
#    spine --help
#    spine ingest <your_file.pdf>
#    spine ask "你的问题"
#    spine ask "你的问题" --online  # 联网搜索
# ═══════════════════════════════════════════════════════════
